@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<IEnumerable<ProjektNeve.Dnn.Dnn_ProjektNeve_HelloWorld.Models.Item>>

@using System.Text.RegularExpressions
@using DotNetNuke.Web.Mvc.Helpers


<style>
    /* Fő konténer - 100% szélesség */
    .calc-container {
        background-color: #1a224a;
        color: white;
        padding: 40px;
        border-radius: 10px;
        font-family: 'Segoe UI', sans-serif;
        text-align: center;
        width: 100%;
        box-sizing: border-box;
    }

    .calc-title {
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 30px;
        text-align: left;
    }

    /* Stepper */
    .stepper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .step {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
    }

    .step-number {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        flex-shrink: 0;
    }

    .step-active .step-number {
        background-color: #f1b400;
        color: #1a224a;
    }

    .step-inactive .step-number {
        background-color: #fff;
        color: #1a224a;
    }

    .step-line {
        flex-grow: 0;
        width: 60px;
        height: 2px;
        background-color: #fff;
    }

    .subtitle {
        font-size: 18px;
        line-height: 1.6;
        margin-bottom: 40px;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
        color: white;
    }

    /* Kisebb kártya/gomb dizájn */
    .card-container {
        display: flex;
        justify-content: center;
        width: 100%;
    }

    .service-card {
        background-color: #f1b400;
        border: 2px solid #f1b400;
        border-radius: 12px;
        /* Kisebb méretek */
        width: 220px;
        height: 130px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        cursor: pointer;
        text-decoration: none !important;
        transition: all 0.3s ease;
        padding: 15px;
        box-sizing: border-box;
    }

        .service-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.3);
            background-color: #fff;
        }

    .card-text {
        color: #1a224a;
        font-size: 18px;
        font-weight: bold;
        line-height: 1.3;
        /* Kényszerített tördelés 2-3 sorba */
        display: block;
    }
</style>

<div class="calc-container">
    <div class="calc-title">Személyre szabott árkalkulátor</div>

    <div class="stepper">
        <div class="step step-active">
            <div class="step-number">1</div>
            <span>Kezdőoldal</span>
        </div>
        <div class="step-line"></div>
        <div class="step step-inactive">
            <div class="step-number">2</div>
            <span>Adatok megadása</span>
        </div>
        <div class="step-line"></div>
        <div class="step step-inactive">
            <div class="step-number">3</div>
            <span>Ár és összegzés</span>
        </div>
    </div>

    <div class="subtitle">
        Tudja meg pontos könyvelési díját pillanatok alatt! Adja meg vállalkozása adatait,
        és az igényeire szabott, azonnali árajánlatot adunk.
    </div>

    <div class="card-container">
        <a href="@Url.Action("Konyveles", "Item")" class="service-card">
            <span class="card-text">
                Kipróbálom!
            </span>
        </a>
    </div>
</div>