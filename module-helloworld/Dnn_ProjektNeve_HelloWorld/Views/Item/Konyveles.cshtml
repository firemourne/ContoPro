@*@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<IEnumerable<ProjektNeve.Dnn.Dnn_ProjektNeve_HelloWorld.Models.Item>>*@
@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage

@using System.Text.RegularExpressions
@using DotNetNuke.Web.Mvc.Helpers


@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage

<div class="calc-container" style="background-color: #1a224a; color: white; padding: 40px; border-radius: 10px; font-family: sans-serif; text-align: center; max-width: 600px; margin: 20px auto;">

    <h1 style="color: white; font-size: 28px; margin-bottom: 30px;">Szükséges adatok megadása</h1>

    <div style="max-width: 450px; margin: 0 auto; text-align: left;">

        <div style="margin-bottom: 20px;">
            <label style="color: #f1b400; font-weight: bold; display: block; margin-bottom: 5px;">Vállalkozási forma</label>
            <select id="cegforma" onchange="updateAdozas()"
                    style="width: 100%; height: 45px !important; padding: 10px; border-radius: 5px; background-color: white !important; color: black !important; display: block !important; visibility: visible !important; opacity: 1 !important; border: 2px solid #f1b400;">
                <option value="" disabled selected>Válasszon...</option>
                <option value="egyeni">Egyéni vállalkozó</option>
                <option value="kft">Kft. / Bt.</option>
            </select>
        </div>

        <div style="margin-bottom: 20px;">
            <label style="color: #f1b400; font-weight: bold; display: block; margin-bottom: 5px;">Adózási mód</label>
            <select id="adozas"
                    style="width: 100%; height: 45px !important; padding: 10px; border-radius: 5px; background-color: white !important; color: black !important; display: block !important; visibility: visible !important; opacity: 1 !important; border: 2px solid #f1b400;">
                <option value="" disabled selected>Válasszon formát előbb...</option>
            </select>
        </div>

        <div style="margin-bottom: 20px;">
            <label style="color: #f1b400; font-weight: bold; display: block; margin-bottom: 5px;">Havi bizonylatszám</label>
            <select id="bizonylat"
                    style="width: 100%; height: 45px !important; padding: 10px; border-radius: 5px; background-color: white !important; color: black !important; display: block !important; visibility: visible !important; opacity: 1 !important; border: 2px solid #f1b400;">
                <option value="" disabled selected>Válasszon...</option>
                <option value="0-20">0 - 20 db</option>
                <option value="21-50">21 - 50 db</option>
                <option value="51-100">51 - 100 db</option>
                <option value="100+">100 db felett</option>
            </select>
        </div>

        <div style="margin-bottom: 20px;">
            <label style="color: #f1b400; font-weight: bold; display: block; margin-bottom: 5px;">Alkalmazottak száma</label>
            <input type="number" id="letszam" value="0" min="0"
                   style="width: 100%; height: 45px !important; padding: 10px; border-radius: 5px; background-color: white !important; color: black !important; display: block !important; visibility: visible !important; border: 2px solid #f1b400; box-sizing: border-box;">
        </div>

        <div style="margin-bottom: 30px;">
            <label style="color: #f1b400; font-weight: bold; display: block; margin-bottom: 5px;">ÁFA kör</label>
            <select id="afa"
                    style="width: 100%; height: 45px !important; padding: 10px; border-radius: 5px; background-color: white !important; color: black !important; display: block !important; visibility: visible !important; opacity: 1 !important; border: 2px solid #f1b400;">
                <option value="" disabled selected>Válasszon...</option>
                <option value="alanyi">Alanyi Adómentes (AAM)</option>
                <option value="afas">ÁFA körös (27%)</option>
            </select>
        </div>

        <button type="button" onclick="szamolas()"
                style="width: 100%; padding: 15px; background-color: #f1b400; color: #1a224a; border: none; border-radius: 5px; font-size: 18px; font-weight: bold; cursor: pointer;">
            AJÁNLAT KÉRÉSE
        </button>

        <div id="eredmeny-box" style="display:none; margin-top: 20px; padding: 15px; border: 1px dashed #f1b400; text-align: center;">
            <span id="eredmeny-text" style="color: #f1b400; font-weight: bold;"></span>
        </div>
    </div>
</div>

<script type="text/javascript">
    function updateAdozas() {
        var c = document.getElementById("cegforma").value;
        var a = document.getElementById("adozas");
        a.innerHTML = '<option value="" disabled selected>Válasszon...</option>';
        var o = [];
        if (c === "egyeni") {
            o = [{ v: "ata", t: "Átalányadó" }, { v: "kata", t: "KATA" }, { v: "vsze", t: "VSZÉ" }];
        } else if (c === "kft") {
            o = [{ v: "tao", t: "TAO" }, { v: "kiva", t: "KIVA" }];
        }
        o.forEach(function (opt) {
            var el = document.createElement("option");
            el.value = opt.v; el.text = opt.t;
            a.appendChild(el);
        });
    }

    function szamolas() {
        if (!document.getElementById("cegforma").value || !document.getElementById("adozas").value) {
            alert("Töltsön ki minden mezőt!"); return;
        }
        document.getElementById("eredmeny-box").style.display = "block";
        document.getElementById("eredmeny-text").innerText = "Ajánlat kalkulálása folyamatban...";
    }
</script>
