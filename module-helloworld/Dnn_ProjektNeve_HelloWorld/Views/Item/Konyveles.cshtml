<style>
    .calc-wrapper {
        background-color: #1a224a;
        color: white;
        padding: 40px;
        border-radius: 10px;
        font-family: sans-serif;
        /* Szélesebbre vesszük, hogy több tér legyen az adatoknak */
        max-width: 1100px;
        margin: 20px auto;
        box-sizing: border-box;
    }

    /* --- Progress Bar --- */
    .calc-progress {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 50px;
        padding: 0 40px;
    }

    .calc-step {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .calc-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: white;
        color: #1a224a;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 18px;
        flex-shrink: 0;
    }

        .calc-circle.active {
            background-color: #f1b400;
        }

    .calc-step-text {
        color: white;
        font-size: 16px;
        white-space: nowrap;
    }

    .calc-line {
        flex-grow: 1;
        min-width: 40px;
        height: 2px;
        background-color: white;
        margin: 0 25px;
    }

        .calc-line.active {
            background-color: #f1b400;
        }

    /* --- Form elemek --- */
    .calc-title {
        text-align: center;
        color: white;
        margin-bottom: 40px;
        font-size: 32px;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-label {
        color: #f1b400;
        font-weight: bold;
        display: block;
        margin-bottom: 8px;
        font-size: 16px;
    }

    .form-control {
        width: 100%;
        height: 50px;
        padding: 10px 15px;
        border-radius: 5px;
        border: 2px solid #f1b400;
        background-color: white;
        color: black;
        box-sizing: border-box;
        font-size: 16px;
    }

    .btn-restart {
        display: block;
        text-align: center;
        text-decoration: none;
        width: 100%;
        padding: 15px;
        background-color: #f1b400;
        color: black;
        border: 2px solid #f1b400;
        border-radius: 5px;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        margin-top: 15px;
        box-sizing: border-box;
        transition: 0.3s;
    }

        .btn-restart:hover {
            background-color: rgba(241, 180, 0, 0.1);
            color: #f1b400
        }
    


</style>

<div class="calc-wrapper">

    <div class="calc-progress">
        <div class="calc-step">
            <div class="calc-circle active">1</div>
            <div class="calc-step-text">Kezdőoldal</div>
        </div>
        <div class="calc-line active"></div>
        <div class="calc-step">
            <div class="calc-circle active">2</div>
            <div class="calc-step-text">Adatok megadása</div>
        </div>
        <div class="calc-line"></div>
        <div class="calc-step">
            <div class="calc-circle">3</div>
            <div class="calc-step-text">Ár és összegzés</div>
        </div>
    </div>
    <h2 class="calc-title">Szükséges adatok megadása</h2>

    <div class="form-group">
        <label class="form-label">Vállalkozási forma</label>
        <select id="cegforma" class="form-control" onchange="updateAdozas()">
            <option value="" disabled selected>Válasszon...</option>
            <option value="egyeni">Egyéni vállalkozó</option>
            <option value="kft">Kft. / Bt.</option>
        </select>
    </div>

    <div class="form-group">
        <label class="form-label">Adózási mód</label>
        <select id="adozas" class="form-control">
            <option value="" disabled selected>Válasszon formát előbb...</option>
        </select>
    </div>

    <div class="form-group">
        <label class="form-label">Havi bizonylatszám</label>
        <select id="bizonylat" class="form-control">
            <option value="" disabled selected>Válasszon...</option>
            <option value="0-20">0 - 20 db</option>
            <option value="21-50">21 - 50 db</option>
            <option value="51-100">51 - 100 db</option>
            <option value="100+">100 db felett</option>
        </select>
    </div>

    @*csak természetes szám kerülhessen az alkalmazottak mezőbe*@
    <div class="form-group">
        <label class="form-label">Alkalmazottak száma</label>
        <input type="number"
               id="letszam"
               class="form-control"
               value="0"
               min="0"
               step="1"
               onkeypress="return event.charCode >= 48 && event.charCode <= 57"
               oninput="this.value = !!this.value && Math.abs(this.value) >= 0 ? Math.floor(Math.abs(this.value)) : 0">
    </div>

    <div class="form-group">
        <label class="form-label">ÁFA kör</label>
        <select id="afa" class="form-control">
            <option value="" disabled selected>Válasszon...</option>
            <option value="alanyi">Alanyi Adómentes (AAM)</option>
            <option value="afas">ÁFA körös (27%)</option>
        </select>
    </div>

    <a href="javascript:void(0);" onclick="Send()" class="btn-restart">
        <div class="card-icon" style="background: url('path-to-your-icon2.png') no-repeat center; background-size: contain;">
        </div>
        <div class="card-text">Ajánlat kérése</div>
    </a>

    <a href="@Url.Action("Index", "Item")" class="btn-restart">
        Újrakezdés
    </a>



</div>




<script>
    function updateAdozas() {
        var formaSelect = document.getElementById("cegforma").value;
        var adozasSelect = document.getElementById("adozas");

        // Ürítjük a listát, és betesszük az alapértelmezett szöveget
        adozasSelect.innerHTML = '<option value="" disabled selected>Válasszon...</option>';

        var opciok = [];

        // Logika: Mi jelenjen meg az adózásnál a választott forma alapján
        if (formaSelect === "egyeni") {
            opciok = [
                { value: "ata", text: "Átalányadó" },
                { value: "kata", text: "KATA" }
            ];
        } else if (formaSelect === "kft") {
            opciok = [
                { value: "tao", text: "TAO (Társasági adó)" },
                { value: "kiva", text: "KIVA" }
            ];
        }

        // Feltöltjük az új opciókkal a második legördülőt
        for (var i = 0; i < opciok.length; i++) {
            var ujElem = document.createElement("option");
            ujElem.value = opciok[i].value;
            ujElem.text = opciok[i].text;
            adozasSelect.appendChild(ujElem);
        }
    }

    function Send() {
        // 1. Kiszedjük az értékeket
        var c = document.getElementById("cegforma").value;
        var a = document.getElementById("adozas").value;
        var b = document.getElementById("bizonylat").value;
        var l = document.getElementById("letszam").value || 0;
        var f = document.getElementById("afa").value;

        // 2. Ellenőrzés
        if (!c || !a || !b || !f) {
            alert("Légyszi tölts ki minden mezőt!");
            return;
        }

        // 3. Alap URL lekérése a DNN-től
        var baseUrl = '@Url.Action("Summary", "Item")';

        // 4. Kérdőjel vagy és-jel (biztonsági játék, ha a DNN eleve tesz bele paramétert)
        var separator = baseUrl.indexOf('?') !== -1 ? '&' : '?';

        var finalUrl = baseUrl + separator + "ceg=" + c + "&ado=" + a + "&bizonylat=" + b + "&letszam=" + l + "&afa=" + f;

        // MEGÁLLÍTJUK A KÓDOT, HOGY LÁSSUK MIT CSINÁLT , teszteléshez volt használva
        //alert("Ezt a linket raktam össze:\n" + finalUrl);

        // Csak ezután engedjük tovább
        window.location.href = finalUrl;
    }







</script>